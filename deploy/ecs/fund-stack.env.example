# 复制为 deploy/ecs/fund-stack.env 后填写（勿提交 Git）

# SQLAlchemy URL（爬虫与 Web 共用）
DATABASE_URL=mysql+pymysql://fund_app:CHANGE_ME@127.0.0.1:3306/fund_svc

# Web 监听（默认与 systemd 单元一致；生产建议仅本机 + Nginx）
FUND_WEB_HOST=127.0.0.1
FUND_WEB_PORT=8010

# Nginx 子路径（无则留空）；示例：https://wanghanai.xyz/quant-funds/
FUND_URL_PREFIX=/quant-funds

# 爬虫日志目录（默认相对 WorkingDirectory：logs/crawler/crawler.log，轮转 5×10MB）
CRAWLER_LOG_DIR=/home/wanghan/quant-trading/logs/crawler

# 爬虫：每日触发时刻（服务器本地时区）
CRAWLER_CRON_HOUR=2
CRAWLER_CRON_MINUTE=0

# 抓取开放式净值快照（关闭可加快速度但列表无净值）
FUND_SYNC_INCLUDE_DAILY=1

# 详情扩展缓存（小时）
FUND_DETAIL_CACHE_HOURS=24

# A 股行业板块资金流向（stock_fund_flow_industry），每日入库
SECTOR_FLOW_PERIODS=即时,3日排行,5日排行,10日排行,20日排行
SECTOR_FLOW_CRON_HOUR=18
SECTOR_FLOW_CRON_MINUTE=30
SECTOR_FLOW_PERIOD_DELAY_SEC=3

# 全 A 股日快照（新浪 spot 主；东财整表补强默认关，见 STOCK_DAILY_EM_ENRICH）
# 默认 17:10，错开指数日收盘 17:00，避免同时打东财
STOCK_DAILY_CRON_HOUR=17
STOCK_DAILY_CRON_MINUTE=10
STOCK_DAILY_EM_ENRICH=0
CRAWLER_STALE_RUN_HOURS=6

# 行业成分股代码列表（同花顺 thshy，仅 code）— 放慢请求避免 403/限流
SECTOR_CONSTITUENTS_ON_SYNC=1
THS_REQUEST_DELAY_SEC=1.5
THS_PAGE_DELAY_SEC=2.0
THS_RETRY_SLEEP_SEC=8
THS_RETRIES=8
SECTOR_CONSTITUENT_DELAY_SEC=2.5
SECTOR_CONSTITUENT_RETRY_PAUSE_SEC=20
SECTOR_CONSTITUENT_RETRY_DELAY_SEC=5
STOCK_DAILY_PAGE_DELAY_SEC=3
STOCK_DAILY_RETRY_SLEEP_SEC=8

# 行业流通市值 = 成分 code JOIN stock_daily 加总(亿)
SECTOR_MARKET_CAP_ON_SYNC=1

# 行业仪表盘：基金季报持仓 → 行业暴露 → 收益指标（DDL 008）
FUND_HOLDINGS_TYPE_KEYWORDS=股票,混合,指数,ETF,QDII
FUND_HOLDINGS_DELAY_SEC=1.0
FUND_HOLDINGS_MAX_PER_RUN=0
FUND_HOLDINGS_CRON_HOUR=3
FUND_HOLDINGS_CRON_MINUTE=0
FUND_HOLDINGS_CRON_DOW=sun
# 基金重仓股统计（持有基金数排行，供持仓反查页展示）
FUND_STOCK_POPULARITY_CRON_HOUR=4
FUND_STOCK_POPULARITY_CRON_MINUTE=30
FUND_STOCK_POPULARITY_MIN_FUNDS=3
FUND_STOCK_POPULARITY_GLOBAL_MIN_FUNDS=2
FUND_METRICS_DELAY_SEC=0.6
FUND_METRICS_MAX_PER_RUN=500
FUND_EXPOSURE_MIN_PCT=10
DASHBOARD_DEFAULT_PERIOD=即时

# 大盘指数：A 股交易日盘中每分钟快照；收盘后写入日 K
MARKET_INDEX_CODES=000001:上证指数,399001:深证成指,399006:创业板指,000300:沪深300,000016:上证50,000688:科创50,000905:中证500
MARKET_INDEX_INTRADAY_CN_INTERVAL_MINUTES=1
MARKET_INDEX_INTERVAL_MINUTES=1
MARKET_INDEX_REQUEST_DELAY_SEC=0.8
MARKET_INDEX_RETRY_SLEEP_SEC=5
MARKET_INDEX_DAILY_CRON_HOUR=17
MARKET_INDEX_DAILY_CRON_MINUTE=0
# 海外/全球（东财名称，逗号分隔）；NDX=纳斯达克100，SPX=标普500
MARKET_INDEX_HK=恒生指数
MARKET_INDEX_HK_DAILY_CRON_HOUR=17
MARKET_INDEX_HK_DAILY_CRON_MINUTE=0
MARKET_INDEX_GLOBAL=标普500,纳斯达克,道琼斯,日经225
MARKET_INDEX_GLOBAL_DAILY_CRON_HOUR=8
# 一次性日 K 回填：730=约两年，0=接口能拉到的全部历史
MARKET_INDEX_BACKFILL_DAYS=730
MARKET_INDEX_GLOBAL_DAILY_CRON_MINUTE=0
