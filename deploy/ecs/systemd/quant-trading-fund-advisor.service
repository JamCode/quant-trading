[Unit]
Description=Fund portfolio daily brief → DingTalk
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/quant-trading
EnvironmentFile=%h/quant-trading/deploy/ecs/fund-stack.env
EnvironmentFile=-%h/quant-trading/.env
Environment=PYTHONPATH=%h/quant-trading/src
ExecStart=%h/miniconda3/envs/quant/bin/python %h/quant-trading/scripts/daily_fund_advisor.py

[Install]
WantedBy=default.target
