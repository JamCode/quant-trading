# 复制为 cloud-assistant.env（勿提交 AK/SK，该文件已在 .gitignore）
#   cp deploy/ecs/cloud-assistant.env.example deploy/ecs/cloud-assistant.env

# 实例所在地域（在 ECS 控制台实例详情页查看）
ECS_REGION_ID=cn-hangzhou

# 实例 ID（形如 i-bp1xxxxxxxx；控制台或 hostname iZbp1xxx 对应 i-bp1xxx）
# 留空则脚本用 ECS_PUBLIC_IP 自动查询
ECS_INSTANCE_ID=

# 用于自动查询实例 ID 的公网 IP
ECS_PUBLIC_IP=47.110.78.65

# RunCommand 超时（秒）
ECS_COMMAND_TIMEOUT=300
